# .env.example — Copy this file to .env and fill in your values.
# Never commit your real .env file to version control!

# Application mode: "development" or "production"
MATRIX_MODE=development

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/matrix_db

# Secret key for external API access
API_KEY=your-api-key-here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# URL for the resistance network endpoint
ZION_ENDPOINT=https://zion.resistance.net/api
